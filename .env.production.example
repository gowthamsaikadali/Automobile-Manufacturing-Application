FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
PORT=5000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME_MINUTES=60
PREFERRED_URL_SCHEME=https
APP_NAME=Automobile Manufacturing Dashboard
PER_PAGE=25
LOG_LEVEL=INFO

# Database connection: choose one
DATABASE_URL=postgresql+psycopg2://app_user:StrongPassword@your-rds-endpoint:5432/automobile_manufacturing
# DATABASE_URL=mysql+pymysql://app_user:StrongPassword@your-rds-endpoint:3306/automobile_manufacturing

# RDS/SQLAlchemy pool settings
DB_POOL_RECYCLE=280
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Admin bootstrap credentials
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=ChangeThisImmediately@123

# Optional: protect /health endpoint by requiring this header:
# X-Health-Token: <value>
HEALTHCHECK_TOKEN=
