# Flask settings
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret-key
PORT=5000
SESSION_COOKIE_SECURE=false
APP_NAME=Automobile Manufacturing Dashboard
PER_PAGE=25

# Database URI
# PostgreSQL example for AWS RDS:
DATABASE_URL=postgresql+psycopg2://db_user:db_password@your-rds-endpoint:5432/automobile_manufacturing

# MySQL example for AWS RDS (uncomment if you prefer MySQL):
# DATABASE_URL=mysql+pymysql://db_user:db_password@your-rds-endpoint:3306/automobile_manufacturing

# Seed/admin defaults
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123
